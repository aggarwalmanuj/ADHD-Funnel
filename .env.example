# Safe template - copy to `.env.local`, fill values, never commit `.env.local`.

# --- Azure Cosmos DB (stores Clarity Call waitlist submissions) ---
# Create an account in the Azure portal, then copy the URI and a key.
COSMOS_ENDPOINT=
COSMOS_KEY=
# Database id. Created automatically on first write if it doesn't exist.
COSMOS_DATABASE=funnel-db

# --- Admin panel ---
# Password to sign in to /admin. Required for the waitlist dashboard.
ADMIN_PASSWORD=
