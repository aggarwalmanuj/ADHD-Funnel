# Safe template — copy to `.env.local`, fill values, never commit `.env.local`.
# See also `.env.local.example` (same template).

# Spreadsheet ID, or paste the full /spreadsheets/d/... URL (either works).
# In Google Sheets: Share → add the service account client_email from your JSON as Editor (fixes 403).
GOOGLE_SHEET_ID=

# Tab name for user data (signups, answers, feedback). Default: Sheet1
GOOGLE_SHEET_TAB_NAME=Sheet1

# Tab name for admin prompts (system prompt, beat prompts, question prompts). Default: Sheet2
GOOGLE_SHEET_PROMPTS_TAB=Sheet2

# Service account — use ONE of the two options below.

# Option A: entire JSON on one line (escape inner quotes if needed). private_key uses \n for newlines.
GOOGLE_SERVICE_ACCOUNT_JSON=

# Option B: base64 the whole service account .json file (recommended on Vercel).
# PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("path\to\key.json"))
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=

# --- OpenRouter (AI beat generation, server-side only) ---
# Used by /api/challenge/stream-beat. Create a key at https://openrouter.ai/keys
# Never commit real keys; copy this file to .env.local and fill values there.
OPENROUTER_API_KEY=

# Model id on OpenRouter (examples: openai/gpt-4o-mini, anthropic/claude-3.5-sonnet).
OPENROUTER_MODEL=openai/gpt-4o-mini

# Site URL for OpenRouter HTTP-Referer header. Use your production URL when deployed.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Admin API Protection (server-side) ---
# Password required for POST /api/admin/prompts. The standalone admin.html sends this via X-Admin-Password header.
ADMIN_API_PASSWORD=

# Comma-separated origins allowed to call admin API (CORS). Leave empty to allow all during dev.
# Example: https://your-site.vercel.app
ADMIN_ALLOWED_ORIGINS=

# Calendly — direct scheduling URL shown on the offer page
CALENDLY_URL=

# --- Stripe (Payments) ---
# Server-only secret key (sk_live_… or sk_test_…). Used by /api/stripe/checkout.
STRIPE_SECRET_KEY=
# Publishable key (safe in client bundle). Currently unused since we use
# Stripe-hosted Checkout; keep for future Elements/embedded usage.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (whsec_…). Get from Stripe Dashboard → Developers →
# Webhooks after adding endpoint at /api/webhooks/stripe.
STRIPE_WEBHOOK_SECRET=

# Public origin used for Stripe success/cancel redirects + sitemap/robots.
# Use the canonical www host so canonical/OG/sitemap URLs all match.
NEXT_PUBLIC_SITE_URL=https://www.aimerge.live

# ──────────────────────────────────────────────────────────────────────────
# Facebook (Meta) Pixel — browser + Conversions API dedupe id support
# ──────────────────────────────────────────────────────────────────────────
# Numeric pixel id from Meta Events Manager. Format-validated server-side
# (/^\d{6,20}$/) before interpolation, so a bad value is a no-op rather
# than a script-injection vector. Unset = pixel disabled.
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=

# ──────────────────────────────────────────────────────────────────────────
# PostHog (analytics + session replay)
# ──────────────────────────────────────────────────────────────────────────
# Project API key (phc_…). Public by design — NEXT_PUBLIC_ is correct.
# Unset = PostHog disabled.
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=

# Dashboard host, used only for toolbar / "Open in PostHog" links.
# Events are proxied through our same-origin /ingest path regardless
# (rewrites in next.config.ts) — that's what defeats ad blockers.
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com

# Opt dev environments into PostHog capture. Leave blank in normal dev
# so localhost clicks don't pollute prod funnels / replays. Set to
# "true" only when you're actively testing the pixel/PostHog wiring.
NEXT_PUBLIC_POSTHOG_ENABLE_DEV=

# --- Funnel sequence enforcement ---
# When "true", the challenge funnel enforces strict step order: a user can
# only reach /question-N, /processing, /beat-N, /summary, /offer after
# completing the previous step. Leave blank (or "false") in dev/test so
# you can deep-link to any step. Set to "true" in production.
NEXT_PUBLIC_ENFORCE_FUNNEL_ORDER=true
