# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored. Do not put secrets in `.env.example`.

GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB_NAME=Sheet1
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_KEY_BASE64=

# OpenRouter — streaming personalised beats (/api/challenge/stream-beat). Keys: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — payment gateway for /api/stripe/checkout
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_SITE_URL=https://www.aimerge.live

# Funnel sequence enforcement — "true" in prod, blank/"false" in dev.
NEXT_PUBLIC_ENFORCE_FUNNEL_ORDER=false
