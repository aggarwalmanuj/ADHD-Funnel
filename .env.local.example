# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored. Do not put secrets in `.env.example`.

# --- Azure Cosmos DB (stores Clarity Call waitlist submissions) ---
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DATABASE=funnel-db

# --- Admin panel ---
# Password to sign in to /admin.
ADMIN_PASSWORD=
